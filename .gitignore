.DS_Store

# Cargo build output
/target/
/target-*/
/target-release-check/
/crates/*/target/stress-artifacts/
/node_modules/

# Internal development documentation
/doc/
/docs/*
!/docs/TASK_RUN_DOMAIN_MODEL.md

# Agent and Claude documentation
!CLAUDE.md
!AGENTS.md

# Python environment
/python/.venv/
/python/scripts/*.py  # User scripts (runtime generated)
!/python/scripts/templates/  # Keep templates

# Hide UV enviroment Dont change
/.uv

# Python cache
__pycache__/
*.py[cod]
*$py.class

.playwright-mcp
.restflow/
.restflow-browser/

# redb database files
:memory:

# WebKit temp files from MediaRecorder
.tmp-voice*

# Claude Code
.claude/

# Editor swap/backup files
*.swp
*.swo
*~

# VS Code local debug configurations
.vscode/launch.json
